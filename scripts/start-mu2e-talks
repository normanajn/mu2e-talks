#!/usr/bin/env bash
# start-mu2e-talks — install/update dependencies, migrate, and start the server
#
# Usage:
#   ./start-mu2e-talks [options]
#
# Options:
#   --admin-password <pass>        Password for the initial admin account on first run
#                                  (or set MU2E_INITIAL_ADMIN_PASSWORD env var)
#   --oidc-secret-file <path>      Path to a file containing the OIDC client secret
#                                  (or set OIDC_CLIENT_SECRET_FILE env var)
#   --oidc-provider-url <url>      OIDC discovery URL or base realm URL
#                                  (or set OIDC_PROVIDER_URL env var)
#   --oidc-client-id <id>          OIDC client ID
#                                  (or set OIDC_CLIENT_ID env var)
#   --google-client-id <id>        Google OAuth2 client ID
#                                  (or set GOOGLE_CLIENT_ID env var)
#   --google-client-secret <sec>   Google OAuth2 client secret
#                                  (or set GOOGLE_CLIENT_SECRET env var)
#   --port <port>                  Port to listen on (default: 8000)
#   --prod                         Bind to 0.0.0.0 and use production settings
#   --no-update                    Skip pip/npm update checks
#   --with-tailwind                Also start the Tailwind CSS watcher
#   --tail                         Tail the server log after starting
#
# Subsequent starts:
#   The script is safe to run repeatedly. It updates packages, runs any pending
#   migrations, and restarts the server if one is already running.

set -euo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'
RED='\033[0;31m'; BOLD='\033[1m'; RESET='\033[0m'
info()    { printf "${CYAN}==> %s${RESET}\n" "$*"; }
success() { printf "${GREEN}✓  %s${RESET}\n" "$*"; }
warn()    { printf "${YELLOW}!  %s${RESET}\n" "$*"; }
error()   { printf "${RED}✗  %s${RESET}\n" "$*" >&2; }
header()  { printf "\n${BOLD}%s${RESET}\n%s\n" "$*" "$(printf '─%.0s' {1..60})"; }

# ── Paths ─────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PID_FILE="$SCRIPT_DIR/.mu2e-talks.pid"
TAILWIND_PID_FILE="$SCRIPT_DIR/.mu2e-talks-tailwind.pid"
LOG_DIR="$SCRIPT_DIR/logs"
LOG_FILE="$LOG_DIR/mu2e-talks.log"

# ── Load .env ─────────────────────────────────────────────────────────────────
# Variables already exported in the shell take precedence over .env values.
if [[ -f "$PROJECT_DIR/.env" ]]; then
  while IFS= read -r _line; do
    [[ "$_line" =~ ^[[:space:]]*(#|$) ]] && continue
    _key="${_line%%=*}"; _key="${_key// /}"
    [[ -z "$_key" || "${!_key+set}" == "set" ]] && continue
    _val="${_line#*=}"
    # Strip matching surrounding quotes ("..." or '...')
    if [[ "${_val:0:1}" == '"' && "${_val: -1}" == '"' ]]; then
      _val="${_val:1:${#_val}-2}"
    elif [[ "${_val:0:1}" == "'" && "${_val: -1}" == "'" ]]; then
      _val="${_val:1:${#_val}-2}"
    fi
    export "$_key=$_val"
  done < "$PROJECT_DIR/.env"
  unset _line _key _val
fi

# ── Argument parsing ──────────────────────────────────────────────────────────
ADMIN_PASSWORD="${MU2E_INITIAL_ADMIN_PASSWORD:-}"
OIDC_SECRET_FILE="${OIDC_CLIENT_SECRET_FILE:-}"
OIDC_PROVIDER_URL="${OIDC_PROVIDER_URL:-}"
OIDC_CLIENT_ID="${OIDC_CLIENT_ID:-}"
GOOGLE_CLIENT_ID="${GOOGLE_CLIENT_ID:-}"
GOOGLE_CLIENT_SECRET="${GOOGLE_CLIENT_SECRET:-}"
HOST="127.0.0.1"
PORT=8000
DO_UPDATE=true
WITH_TAILWIND=false
TAIL_LOG=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --admin-password)       ADMIN_PASSWORD="$2";       shift 2 ;;
    --oidc-secret-file)     OIDC_SECRET_FILE="$2";     shift 2 ;;
    --oidc-provider-url)    OIDC_PROVIDER_URL="$2";    shift 2 ;;
    --oidc-client-id)       OIDC_CLIENT_ID="$2";       shift 2 ;;
    --google-client-id)     GOOGLE_CLIENT_ID="$2";     shift 2 ;;
    --google-client-secret) GOOGLE_CLIENT_SECRET="$2"; shift 2 ;;
    --port)              PORT="$2";              shift 2 ;;
    --prod)              HOST="0.0.0.0"; export DJANGO_SETTINGS_MODULE="${DJANGO_SETTINGS_MODULE:-mu2e_talks.settings.prod}"; shift ;;
    --no-update)         DO_UPDATE=false;        shift ;;
    --with-tailwind)     WITH_TAILWIND=true;     shift ;;
    --tail)              TAIL_LOG=true;          shift ;;
    -h|--help)
      awk '/^# Usage:/{show=1} show && /^#/{sub(/^# ?/, ""); print; next} show{exit}' "$0"; exit 0 ;;
    *) error "Unknown option: $1"; exit 1 ;;
  esac
done

cd "$PROJECT_DIR"

header "Mu2eTalks — Start"

# ── Stop any running instance ─────────────────────────────────────────────────
if [[ -f "$PID_FILE" ]]; then
  OLD_PID=$(cat "$PID_FILE")
  if kill -0 "$OLD_PID" 2>/dev/null; then
    warn "Server already running (PID $OLD_PID) — restarting..."
    kill "$OLD_PID" 2>/dev/null || true
    sleep 1
  fi
  rm -f "$PID_FILE"
fi

# ── Python 3.12+ ──────────────────────────────────────────────────────────────
info "Locating Python 3.12+..."
PYTHON=""
for cmd in python3.12 python3.13 python3 python; do
  if command -v "$cmd" &>/dev/null; then
    if "$cmd" -c 'import sys; sys.exit(0 if sys.version_info >= (3,12) else 1)' 2>/dev/null; then
      PYTHON="$cmd"
      break
    fi
  fi
done

if [[ -z "$PYTHON" ]]; then
  error "Python 3.12 or newer is required but was not found."
  echo "  macOS:  brew install python@3.12"
  echo "  Ubuntu: sudo apt install python3.12 python3.12-venv"
  echo "  See docs/quickstart.md for full instructions."
  exit 1
fi
success "Found $("$PYTHON" --version)"

# ── Virtual environment ───────────────────────────────────────────────────────
if [[ ! -d .venv ]]; then
  info "Creating virtual environment (.venv)..."
  "$PYTHON" -m venv .venv
  success "Virtual environment created"
fi
# shellcheck source=/dev/null
source .venv/bin/activate
success "Virtual environment active"

# ── Python packages ───────────────────────────────────────────────────────────
if [[ "$DO_UPDATE" == true ]]; then
  info "Updating Python dependencies..."
  pip install -q --upgrade pip
  pip install -q -r requirements-dev.txt
  success "Python dependencies up to date"
else
  info "Skipping package update (--no-update)"
fi

# ── Node / Tailwind ───────────────────────────────────────────────────────────
if [[ "$DO_UPDATE" == true ]] && command -v npm &>/dev/null; then
  info "Updating Node dependencies..."
  (cd theme/static_src && npm install --silent)
  success "Node dependencies up to date"
fi

# ── Database ──────────────────────────────────────────────────────────────────
header "Database"

info "Applying migrations..."
python manage.py migrate -v 0
success "Migrations applied"

if [[ -n "$ADMIN_PASSWORD" ]]; then
  info "Seeding admin account..."
  MU2E_INITIAL_ADMIN_PASSWORD="$ADMIN_PASSWORD" python manage.py seed_admin
  success "Admin account: mu2e-admin@fnal.gov"
fi

# ── Tailwind watcher (optional) ───────────────────────────────────────────────
if [[ "$WITH_TAILWIND" == true ]]; then
  if command -v npm &>/dev/null; then
    # Stop existing watcher if running
    if [[ -f "$TAILWIND_PID_FILE" ]]; then
      OLD_TW=$(cat "$TAILWIND_PID_FILE")
      kill "$OLD_TW" 2>/dev/null || true
      rm -f "$TAILWIND_PID_FILE"
    fi
    info "Starting Tailwind CSS watcher..."
    mkdir -p "$LOG_DIR"
    (cd "$PROJECT_DIR/theme/static_src" && npm start >> "$LOG_DIR/mu2e-talks-tailwind.log" 2>&1) &
    echo $! > "$TAILWIND_PID_FILE"
    success "Tailwind watcher started (PID $(cat "$TAILWIND_PID_FILE"))"
  else
    warn "npm not found — skipping Tailwind watcher (CDN will be used)"
  fi
fi

# ── Start server ──────────────────────────────────────────────────────────────
header "Server"

mkdir -p "$LOG_DIR"

info "Starting server on $HOST:$PORT..."

if [[ -n "$OIDC_SECRET_FILE" || -n "$OIDC_PROVIDER_URL" ]]; then
  success "OIDC SSO enabled"
  [[ -n "$OIDC_SECRET_FILE" ]] && success "  Secret file: $OIDC_SECRET_FILE"
fi

if [[ -n "$GOOGLE_CLIENT_ID" && -n "$GOOGLE_CLIENT_SECRET" ]]; then
  success "Google OAuth enabled"
fi

export OIDC_CLIENT_SECRET_FILE="$OIDC_SECRET_FILE"
export OIDC_PROVIDER_URL="$OIDC_PROVIDER_URL"
export OIDC_CLIENT_ID="$OIDC_CLIENT_ID"
export GOOGLE_CLIENT_ID="$GOOGLE_CLIENT_ID"
export GOOGLE_CLIENT_SECRET="$GOOGLE_CLIENT_SECRET"
nohup python manage.py runserver "$HOST:$PORT" >> "$LOG_FILE" 2>&1 &
SERVER_PID=$!
echo "$SERVER_PID" > "$PID_FILE"

# Brief pause to catch immediate startup failures
sleep 1
if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  error "Server failed to start. Check the log:"
  echo "  tail -30 $LOG_FILE"
  rm -f "$PID_FILE"
  exit 1
fi

success "Server started   (PID $SERVER_PID)"
success "URL:             http://$HOST:$PORT"
success "Log:             $LOG_FILE"
[[ -n "$ADMIN_PASSWORD" ]] && success "Login:           mu2e-admin@fnal.gov / $ADMIN_PASSWORD"
echo ""
printf "${CYAN}To stop:${RESET}  ./scripts/stop-mu2e-talks\n"

if [[ "$TAIL_LOG" == true ]]; then
  echo ""
  info "Tailing server log (Ctrl-C to stop tailing — server keeps running)..."
  echo ""
  tail -f "$LOG_FILE"
fi
