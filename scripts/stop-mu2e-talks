#!/usr/bin/env bash
# stop-mu2e-talks — gracefully stop the running Mu2eTalks server
#
# Usage:
#   ./stop-mu2e-talks [--tail]
#
# Options:
#   --tail    Print the last 20 lines of the server log before stopping

set -euo pipefail

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'
RED='\033[0;31m'; RESET='\033[0m'
success() { printf "${GREEN}✓  %s${RESET}\n" "$*"; }
warn()    { printf "${YELLOW}!  %s${RESET}\n" "$*"; }
info()    { printf "${CYAN}==> %s${RESET}\n" "$*"; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_FILE="$SCRIPT_DIR/.mu2e-talks.pid"
TAILWIND_PID_FILE="$SCRIPT_DIR/.mu2e-talks-tailwind.pid"
LOG_FILE="$SCRIPT_DIR/logs/mu2e-talks.log"

TAIL_LOG=false
[[ "${1:-}" == "--tail" ]] && TAIL_LOG=true

if [[ "$TAIL_LOG" == true && -f "$LOG_FILE" ]]; then
  echo ""
  info "Last 20 lines of server log:"
  echo ""
  tail -20 "$LOG_FILE"
  echo ""
fi

# ── Stop Django server ────────────────────────────────────────────────────────
if [[ ! -f "$PID_FILE" ]]; then
  warn "No PID file found at $PID_FILE — server may not be running."
else
  PID=$(cat "$PID_FILE")
  if kill -0 "$PID" 2>/dev/null; then
    info "Stopping server (PID $PID)..."
    kill "$PID"
    # Wait up to 5 s for a clean exit
    for _ in {1..10}; do
      kill -0 "$PID" 2>/dev/null || break
      sleep 0.5
    done
    if kill -0 "$PID" 2>/dev/null; then
      kill -9 "$PID" 2>/dev/null || true
    fi
    success "Server stopped"
  else
    warn "Process $PID is no longer running (stale PID file removed)"
  fi
  rm -f "$PID_FILE"
fi

# ── Stop Tailwind watcher (if running) ───────────────────────────────────────
if [[ -f "$TAILWIND_PID_FILE" ]]; then
  TW_PID=$(cat "$TAILWIND_PID_FILE")
  if kill -0 "$TW_PID" 2>/dev/null; then
    info "Stopping Tailwind watcher (PID $TW_PID)..."
    kill "$TW_PID" 2>/dev/null || true
    success "Tailwind watcher stopped"
  fi
  rm -f "$TAILWIND_PID_FILE"
fi
