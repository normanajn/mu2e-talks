# Copy this file to .env and fill in values for your environment.

DJANGO_SECRET_KEY=change-me-50-chars-minimum-random-string-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ACCOUNT_EMAIL_VERIFICATION=optional

# Leave DATABASE_URL unset for local SQLite.
# DATABASE_URL=postgres://mu2etalks:change-me@localhost:5432/mu2etalks
# POSTGRES_DB=mu2etalks
# POSTGRES_USER=mu2etalks
# POSTGRES_PASSWORD=change-me

# Production / Docker
# DJANGO_SETTINGS_MODULE=mu2e_talks.settings.prod
# GUNICORN_WORKERS=3
# MU2E_HOSTNAME=mu2e-talks.fnal.gov

# First-run admin account
MU2E_INITIAL_ADMIN_USERNAME=mu2e-admin
MU2E_INITIAL_ADMIN_EMAIL=mu2e-admin@fnal.gov
MU2E_INITIAL_ADMIN_PASSWORD=change-me

# OIDC / Fermilab SSO
# OIDC_PROVIDER_URL=https://kc.apps.okddev.fnal.gov/realms/myrealm/.well-known/openid-configuration
# OIDC_CLIENT_ID=mu2e-talks
# OIDC_CLIENT_SECRET_FILE=/etc/mu2e-talks/oidc_secret
# OIDC_CLIENT_SECRET=

# Google OAuth, optional
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Set to 1 to block new local account sign-ups once SSO is working.
MU2E_DISABLE_LOCAL_SIGNUP=0
LOCAL_LOGIN_ENABLED=0
